<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/ontologi/jajanan-pasar#"
     xml:base="http://www.semanticweb.org/ontologi/jajanan-pasar"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:jp="http://www.semanticweb.org/ontologi/jajanan-pasar#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar">
        <rdfs:comment>Ontologi untuk sistem pencarian semantik jajanan pasar tradisional Indonesia, mencakup informasi bahan, teknik memasak, daerah asal, dan konteks budaya.</rdfs:comment>
        <rdfs:label>Ontologi Jajanan Pasar Tradisional Indonesia</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#berasalDari -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#berasalDari">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#DaerahAsal"/>
        <rdfs:label>berasal dari</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#dibuatDengan -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#dibuatDengan">
        <owl:equivalentProperty rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#madeFrom"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#TeknikMemasak"/>
        <rdfs:label>dibuat dengan</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#digunakanDi -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#digunakanDi">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#SebutanRegional"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#DaerahAsal"/>
        <rdfs:label>digunakan di</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#disajikanPada -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#disajikanPada">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Acara"/>
        <rdfs:label>disajikan pada</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#madeFrom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#madeFrom">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#CaraMembuat"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#memilikiSebutan -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#memilikiSebutan">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#SebutanRegional"/>
        <rdfs:label>memiliki sebutan</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#memilikiTekstur -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#memilikiTekstur">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Tekstur"/>
        <rdfs:label>memiliki tekstur</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#menggunakanBahan -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#menggunakanBahan">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Bahan"/>
        <rdfs:label>menggunakan bahan</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#serumpunDengan -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#serumpunDengan">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:comment>Relasi antara jajanan yang memiliki kesamaan bahan atau teknik.</rdfs:comment>
        <rdfs:label>serumpun dengan</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#deskripsi -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#deskripsi">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>deskripsi</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#hargaRataRata -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#hargaRataRata">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>harga rata-rata</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#namaLain -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#namaLain">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>nama lain</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#namaLokal -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#namaLokal">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>nama lokal</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#namaSebutan -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#namaSebutan">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#SebutanRegional"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>nama sebutan</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#rasaDominan -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#rasaDominan">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>rasa dominan</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#tahanLama -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#tahanLama">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>tahan lama</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#warnaUtama -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#warnaUtama">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>warna utama</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#Acara -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#Acara">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Event"/>
        <rdfs:comment>Konteks acara atau tradisi di mana jajanan disajikan.</rdfs:comment>
        <rdfs:label>Acara</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#AcaraAdat -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#AcaraAdat">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Acara"/>
        <rdfs:label>Acara Adat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#Bahan -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#Bahan">
        <rdfs:comment>Bahan-bahan yang digunakan dalam pembuatan jajanan pasar.</rdfs:comment>
        <rdfs:label>Bahan</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#BahanPelengkap -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#BahanPelengkap">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Bahan"/>
        <rdfs:label>Bahan Pelengkap</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#BahanPewarna -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#BahanPewarna">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Bahan"/>
        <rdfs:label>Bahan Pewarna</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#BahanUtama -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#BahanUtama">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Bahan"/>
        <rdfs:label>Bahan Utama</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#BerbahanKetan -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#BerbahanKetan">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananBasah"/>
        <rdfs:label>Berbahan Ketan</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#BerbahanSantan -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#BerbahanSantan">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananBasah"/>
        <rdfs:label>Berbahan Santan</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#BerbahanSingkong -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#BerbahanSingkong">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananBasah"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#BerbahanUbi -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#BerbahanUbi">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananBasah"/>
        <rdfs:label>Berbahan Ubi</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#CaraMembuat -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#CaraMembuat">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#TeknikMemasak"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#DaerahAsal -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#DaerahAsal">
        <rdfs:comment>Daerah atau wilayah asal jajanan di Indonesia.</rdfs:comment>
        <rdfs:label>Daerah Asal</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#Event -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#Event"/>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#Gorengan -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#Gorengan">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananKering"/>
        <rdfs:label>Gorengan</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#JajananBasah -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananBasah">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:comment>Jajanan dengan kandungan air tinggi, tidak tahan lama.</rdfs:comment>
        <rdfs:label>Jajanan Basah</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#JajananKering -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananKering">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar"/>
        <rdfs:comment>Jajanan dengan kadar air rendah, lebih tahan lama.</rdfs:comment>
        <rdfs:label>Jajanan Kering</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananPasar">
        <rdfs:comment>Kelas utama yang merepresentasikan makanan/kue tradisional yang dijual di pasar tradisional Indonesia.</rdfs:comment>
        <rdfs:label>Jajanan Pasar</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#KuePanggang -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#KuePanggang">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananKering"/>
        <rdfs:label>Kue Panggang</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#PasarTradisional -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#PasarTradisional">
        <rdfs:label>Pasar Tradisional</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#SebutanRegional -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#SebutanRegional">
        <rdfs:label>Sebutan Regional</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#TeknikMemasak -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#TeknikMemasak">
        <rdfs:comment>Metode pengolahan yang digunakan dalam pembuatan jajanan.</rdfs:comment>
        <rdfs:label>Teknik Memasak</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#Tekstur -->

    <owl:Class rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#Tekstur">
        <rdfs:label>Tekstur</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#Adrem -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#Adrem">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Gorengan"/>
        <memilikiSebutan rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Adrem_SebutanSunda"/>
        <berasalDari rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Jawa"/>
        <dibuatDengan rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Digoreng"/>
        <disajikanPada rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#PasarPagi"/>
        <madeFrom rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Digoreng"/>
        <memilikiTekstur rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Renyah"/>
        <menggunakanBahan rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#TepungBeras"/>
        <deskripsi>Jajanan manis Bantul terbuat dari tepung beras dan gula merah, dijepit sumpit bambu saat digoreng.</deskripsi>
        <hargaRataRata rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1500.0</hargaRataRata>
        <namaLain>tolpit</namaLain>
        <namaLokal>kue adrem</namaLokal>
        <rasaDominan>manis gurih</rasaDominan>
        <tahanLama rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</tahanLama>
        <warnaUtama>coklat tua</warnaUtama>
        <rdfs:label>Kue Adrem</rdfs:label>
    </owl:NamedIndividual>
    

    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#Adrem_SebutanSunda -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#Adrem_SebutanSunda">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#SebutanRegional"/>
        <digunakanDi rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Sunda"/>
        <namaSebutan>tolpit</namaSebutan>
        <rdfs:label>Adrem Sebutan Sunda</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ontologi/jajanan-pasar#AkarKelapa -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ontologi/jajanan-pasar#AkarKelapa">
        <rdf:type rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#JajananBasah"/>
        <namaLokal>akar kelapa</namaLokal>
        <memilikiSebutan rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#AkarKelapa_SebutanBetawi"/>
        <berasalDari rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Jawa"/>
        <dibuatDengan rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Dikukus"/>
        <disajikanPada rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#PasarPagi"/>
        <madeFrom rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Dikukus"/>
        <memilikiTekstur rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#Lembut"/>
        <menggunakanBahan rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#KelapaParut"/>
        <menggunakanBahan rdf:resource="http://www.semanticweb.org/ontologi/jajanan-pasar#TepungBeras"/>
        <deskripsi>AkarKelapa merupakan salah satu jajanan pasar tradisional Indonesia.</deskripsi>
        <hargaRataRata rdf:datatype="http://www.w3.org/2001/XMLSchema#float">3000.0</hargaRataRata>
        <namaLain>AkarKelapa</namaLain>
        <rasaDominan>manis</rasaDominan>
        <tahanLama rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</tahanLama>
        <warnaUtama>coklat</warnaUtama>
